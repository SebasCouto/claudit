{
  "description": "claudit — genera el reporte HTML en .claudit/ automaticamente al cerrar la sesion (una sola vez por sesion)",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claudit.py\" --html",
            "timeout": 20,
            "async": true
          }
        ]
      }
    ]
  }
}
